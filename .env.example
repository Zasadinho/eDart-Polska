# 🔐 ACE Darts Arena - Security Environment Variables
# Copy this file to .env.local and fill in the actual values
# NEVER commit .env.local to version control

# ─── Supabase Configuration ───
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Security Headers ───
# These are configured in vercel.json, but can be overridden here
VITE_SECURITY_HEADERS_ENABLED=true

# ─── Session Configuration ───
# Session timeout in minutes
VITE_SESSION_TIMEOUT=60

# ─── Password Policy ───
# Minimum password length (should be at least 12)
VITE_MIN_PASSWORD_LENGTH=12
# Require uppercase letters
VITE_PASSWORD_REQUIRE_UPPERCASE=true
# Require numbers
VITE_PASSWORD_REQUIRE_NUMBERS=true
# Require special characters
VITE_PASSWORD_REQUIRE_SPECIAL=true

# ─── File Upload Configuration ───
# Maximum file size for avatars (in MB)
VITE_MAX_AVATAR_SIZE=5
# Allowed image types (comma-separated)
VITE_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
# Maximum file size for match screenshots (in MB)
VITE_MAX_SCREENSHOT_SIZE=10

# ─── API Rate Limiting ───
# Requests per minute per IP
VITE_RATE_LIMIT_REQUESTS=60
VITE_RATE_LIMIT_WINDOW=60000

# ─── Audit Logging ───
# Enable audit logging of all admin actions
VITE_AUDIT_LOGGING_ENABLED=true
# Log IP addresses (requires compliance review)
VITE_LOG_IP_ADDRESSES=true
# Retain audit logs for N days
VITE_AUDIT_LOG_RETENTION_DAYS=90

# ─── Feature Flags ───
# Enable strict mode for additional security checks
VITE_STRICT_MODE=true
